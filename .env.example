PORT=3000
DATABASE_PATH=./moca.db
VOICEPEAK=/path/to/voicepeak
MOCA_NARRATOR=Miyamai Moca
MOCA_URL=http://localhost:3000

# 英単語→カタカナのフォールバック辞書 (bep-eng.dic 由来)。GPLv2 のため同梱せず起動時に DL する。
# キャッシュが無ければ BEP_DICT_URL から取得し BEP_DICT_PATH へ保存する (失敗時は無効化して起動継続)。
BEP_DICT_PATH=./bep-eng.dic
BEP_DICT_URL=https://raw.githubusercontent.com/uesugi6111/alkana-rs/master/dictionary.csv

ANALYZE_BACKEND=none
ANALYZE_CMD=claude -p --model haiku
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
