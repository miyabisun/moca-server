PORT=3000
DATABASE_PATH=./moca.db
VOICEPEAK=/path/to/voicepeak
MOCA_NARRATOR=Miyamai Moca
MOCA_URL=http://localhost:3000

# 英単語→カタカナのフォールバック辞書 (bep-eng.dic 由来)。GPLv2 のため同梱せず起動時に DL する。
# キャッシュが無ければ BEP_DICT_URL から取得し BEP_DICT_PATH へ保存する (失敗時は無効化して起動継続)。
BEP_DICT_PATH=./bep-eng.dic
BEP_DICT_URL=https://raw.githubusercontent.com/uesugi6111/alkana-rs/master/dictionary.csv

ANALYZE_BACKEND=none
ANALYZE_CMD=claude -p --model haiku
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 作業タブ (ポモドーロ+声かけ)。立ち絵素材は再配布禁止のため非同梱 —
# 無ければ起動時に MOCA_ILLUST_URL (既定: 公式サイト、約150MB) から自動 DL して
# MOCA_ASSETS_DIR へ展開する (docs/config.md「作業タブの立ち絵素材」参照)。
# 手動配置したい場合は MOCA_ILLUST_URL= (空) で自動 DL を無効化する。
#MOCA_ASSETS_DIR=./moca-assets
#MOCA_ILLUST_URL=https://www.ah-soft.com/moca/moca_illust.zip
# 時事ネタ声かけ専用の CLI (Web 検索可能なものを推奨)。未設定なら ANALYZE_BACKEND に従う。
#WORK_NEWS_CMD=claude -p --allowed-tools WebSearch
# /work/talk のサーバ側タイムアウト秒 (既定 60)
#WORK_TALK_TIMEOUT_SECS=60
