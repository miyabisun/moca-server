#!/usr/bin/env bash
# moca-render — 台本 JSONL を VOICEPEAK (宮舞モカ) で合成し、生PCM (s16le / 48kHz / mono) を stdout に流す
#
# 入力: stdin に 1行 = 1 segment の JSON
#   {"text":"こんにちは。","emotion":{"honwaka":60},"speed":110,"pitch":20,"pause":500}
#   - text 以外は省略可
#   - emotion: bosoboso / doyaru / honwaka / angry / teary (各 0-100)
#   - speed: 50-200, pitch: -300〜300 (VOICEPEAK CLI にそのまま渡す)
#   - pause: この文の後に挟む無音 (ms)。無音PCMを生成するだけなのでエンジン非依存
#
# segment 単位で逐次合成するので、下流は最初の segment から再生を始められる。
set -euo pipefail

# 非対話 ssh や systemd 経由だとロケールが POSIX になり UTF-8 処理が壊れるため固定する
export LC_ALL=ja_JP.utf8

VOICEPEAK="${VOICEPEAK:-$HOME/tools/Voicepeak/voicepeak}"
NARRATOR="${MOCA_NARRATOR:-Miyamai Moca}"

BYTES_PER_MS=96 # 48000Hz * 16bit * 1ch = 96000 bytes/s

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

while IFS= read -r seg; do
  [ -z "$seg" ] && continue

  text=$(jq -r '.text // empty' <<<"$seg")
  [ -z "$text" ] && continue

  args=(-s "$text" -n "$NARRATOR" -o "$tmpdir/s.wav")
  emotion=$(jq -r '(.emotion // {}) | to_entries | map("\(.key)=\(.value)") | join(",")' <<<"$seg")
  speed=$(jq -r '.speed // empty' <<<"$seg")
  pitch=$(jq -r '.pitch // empty' <<<"$seg")
  pause=$(jq -r '.pause // 0' <<<"$seg")
  [ -n "$emotion" ] && args+=(-e "$emotion")
  [ -n "$speed" ] && args+=(--speed "$speed")
  [ -n "$pitch" ] && args+=(--pitch "$pitch")

  # voicepeak はデバッグログを stdout に吐くので PCM ストリームから隔離しつつ、
  # 失敗時だけ stderr へ出す。稀に起動直後に即死することがあるためリトライする
  ok=""
  for attempt in 1 2 3; do
    if vp_log=$("$VOICEPEAK" "${args[@]}" 2>&1); then
      ok=1
      break
    fi
    echo "moca-render: voicepeak failed (attempt $attempt) for: $text" >&2
  done
  if [ -z "$ok" ]; then
    printf '%s\n' "$vp_log" "moca-render: giving up: $text" >&2
    exit 1
  fi

  ffmpeg -v error -i "$tmpdir/s.wav" -f s16le -

  if [ "$pause" -gt 0 ] 2>/dev/null; then
    head -c $((pause * BYTES_PER_MS)) /dev/zero
  fi
done
